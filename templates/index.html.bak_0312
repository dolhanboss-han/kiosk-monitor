<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BSEYE Kiosk Monitor</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="/static/css/widget-common.css">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',sans-serif;overflow:auto}

.header{
    position:fixed;top:0;left:0;right:0;z-index:1000;
    background:#111130;padding:8px 20px;
    display:flex;align-items:center;justify-content:space-between;
    border-bottom:1px solid #333;height:60px;
}
.header .logo{font-size:1.9rem;font-weight:700;color:#eee;white-space:nowrap}
.header .logo em{color:#00d4ff;font-style:normal}
.header .nav{display:flex;gap:6px;align-items:center;flex-wrap:nowrap}
.header .nav a{
    color:#999;text-decoration:none;font-size:1.15rem;
    padding:4px 10px;border:1px solid #333;border-radius:6px;
    white-space:nowrap;transition:all 0.2s;
}
.header .nav a:hover,.header .nav a.active{color:#00d4ff;border-color:#00d4ff}
.header .right{display:flex;gap:10px;align-items:center}
.header .user{color:#aaa;font-size:1.15rem;white-space:nowrap}
.header .user a{color:#ff6b6b;text-decoration:none;margin-left:8px;font-size:1.1rem}

#canvas{
    width:1920px;min-height:calc(100vh - 60px);
    position:relative;margin:68px 0 0 0;
    background:var(--bg);border-radius:8px;
}

body.light .header{background:linear-gradient(135deg,#f8f9fc,#eef1f5)!important;border-bottom:1px solid #d0d5dd!important;box-shadow:0 1px 4px rgba(0,0,0,.06)}
body.light .header .logo{color:#1a1a2e}
body.light .header .nav a{color:#555}
body.light .header .nav a:hover{color:#2563eb}
body.light .header .clk{color:#555}
body.light .header .user{color:#666}

@media(max-width:768px){
    .header{padding:6px 10px!important;height:auto!important;flex-wrap:wrap;gap:6px}
    .clk{font-size:0.65rem!important}
    .header .logo{font-size:0.95rem}
    .header .right{display:none!important}
    .header .nav{overflow-x:auto;flex-wrap:nowrap;gap:4px}
    .header .nav a{font-size:0.7rem;padding:3px 6px}
    #canvas{width:100%!important;margin-top:60px;display:flex!important;flex-direction:column;gap:8px;padding:8px;min-height:auto!important;height:auto!important}
    .widget{position:relative!important;left:auto!important;top:auto!important;width:100%!important;height:auto!important;min-height:80px}
    .widget .w-body{height:auto!important;min-height:60px;overflow:visible!important}
    .widget .w-body canvas{max-width:100%!important;height:200px!important}
    .widget .w-body table{width:100%!important}
    .widget .w-body th,.widget .w-body td{font-size:0.65em!important;padding:2px 3px!important}
}
</style>
</head>
<body>

<div class="header">
    <span class="logo"><em style="color:#00d4ff;font-style:normal">BS</em>EYE <span style="font-size:0.82rem;font-weight:400;color:#a0b0c0;margin-left:6px">대시보드</span></span>
    {% include 'nav.html' %}
    <span class="clk" id="clk" style="font-size:0.7rem;color:#a0b0c0;white-space:nowrap"></span>
    <div class="right">
        <span class="user">{{ session.get('user_name', '') }} ({{ session.get('user_role', '') }})</span>
        <span class="user"><a href="/change-password">비밀번호</a> <a href="/logout">로그아웃</a></span>
    </div>
</div>
<div id="canvas"></div>
<div id="dash-indicator" onmouseenter="this.style.opacity='1'" onmouseleave="this.style.opacity='0.3'" style="position:fixed;bottom:14px;right:18px;z-index:9999;display:flex;gap:14px;align-items:center;background:rgba(10,10,30,0.92);border:1px solid #444;border-radius:12px;padding:12px 18px;color:#eee;opacity:0.3;transition:opacity 0.3s ease">
<span style="color:#888;font-size:1rem">배율</span>
<button onclick="changeScale(-0.01)" style="width:36px;height:36px;background:#333;color:#eee;border:1px solid #555;border-radius:6px;cursor:pointer;font-size:1.2rem;font-weight:bold;display:flex;align-items:center;justify-content:center">−</button>
<span id="scale-display" style="color:#00d4ff;font-weight:bold;font-size:1.1rem;min-width:60px;text-align:center">x1.00</span>
<button onclick="changeScale(0.01)" style="width:36px;height:36px;background:#333;color:#eee;border:1px solid #555;border-radius:6px;cursor:pointer;font-size:1.2rem;font-weight:bold;display:flex;align-items:center;justify-content:center">+</button>
<span style="color:#444;font-size:1.2rem;margin:0 2px">|</span>
<span style="color:#888;font-size:1rem">갱신</span>
<button onclick="changeInterval(-10)" style="width:36px;height:36px;background:#333;color:#eee;border:1px solid #555;border-radius:6px;cursor:pointer;font-size:1.2rem;font-weight:bold;display:flex;align-items:center;justify-content:center">−</button>
<span id="refresh-timer" style="color:#00ff88;font-weight:bold;font-size:1.1rem;min-width:60px;text-align:center">60초</span>
<button onclick="changeInterval(10)" style="width:36px;height:36px;background:#333;color:#eee;border:1px solid #555;border-radius:6px;cursor:pointer;font-size:1.2rem;font-weight:bold;display:flex;align-items:center;justify-content:center">+</button>
</div>

<script src="/static/js/widget-render.js"></script>
<script>
const canvas = document.getElementById('canvas');
let WIDGET_DEFS = {};


function renderWidget(el, type) {
    const header = el.querySelector('.w-header');
    const body = el.querySelector('.w-body');
    if(!header||!body) return;
    header.textContent = LABELS[type] || type;
    const id = el.id || 'dash_' + Math.random().toString(36).slice(2);
    el.id = id;
    body.id = 'body_' + id;
    renderWidgetContent(el, body, type, id).then(()=>{
        applyWidgetScale(el);
    });
}

let _manualScale = Math.min(1, window.innerWidth / 1920);
if(_manualScale < 0.5) _manualScale = 1;
_manualScale = Math.round(_manualScale * 100) / 100;

function layoutScale(){
    if(window.innerWidth < 768) return 1;
    return _manualScale;
}

function changeScale(delta){
    _manualScale = Math.round((_manualScale + delta) * 100) / 100;
    if(_manualScale < 0.25) _manualScale = 0.25;
    if(_manualScale > 2.0) _manualScale = 2.0;
    const sd=document.getElementById('scale-display');
    if(sd) sd.textContent='x'+_manualScale.toFixed(2);
    if(_layoutData) renderLayout(_layoutData);
}

function renderLayout(layout){
    canvas.innerHTML='';
    const items = Array.isArray(layout) ? layout : (layout.layout || []);
    if(!items||items.length===0){
        canvas.innerHTML='<div style="text-align:center;padding:60px;color:#666;font-size:1.2em">저장된 레이아웃이 없습니다. 에디터에서 위젯을 배치하고 저장하세요.</div>';
        return;
    }
    const s = layoutScale();
    let maxBottom = 0;
    items.forEach(w => { const b = (w.y + w.h) * s; if (b > maxBottom) maxBottom = b; });
    canvas.style.width = Math.round(1920 * s) + 'px';
    canvas.style.minHeight = Math.max(maxBottom + 20, window.innerHeight - 60) + 'px';

    items.forEach(w => {
        const div = document.createElement('div');
        div.className = 'widget';
        div.style.left = Math.round(w.x * s) + 'px';
        div.style.top = Math.round(w.y * s) + 'px';
        div.style.width = Math.round(w.w * s) + 'px';
        div.style.height = Math.round(w.h * s) + 'px';
        div.setAttribute('data-type', w.type);
        div.innerHTML = '<div class="w-header"></div><div class="w-body"></div>';
        canvas.appendChild(div);
        renderWidget(div, w.type);
    });
    const sd=document.getElementById('scale-display');
    if(sd) sd.textContent='x'+_manualScale.toFixed(2);
}

let _layoutData = null;
fetch('/api/widgets').then(r=>r.json()).then(d=>{
    d.widgets.forEach(w=>{ WIDGET_DEFS[w.key]={w:w.w,h:w.h,label:w.name}; });
}).then(()=>{
    fetch('/api/layout').then(r=>r.json()).then(layout=>{
        _layoutData = layout;
        renderLayout(_layoutData);
    });
});

// 화면 리사이즈 시 재렌더링
let _resizeTimer;
window.addEventListener('resize', ()=>{
    clearTimeout(_resizeTimer);
    _resizeTimer = setTimeout(()=>{
        if(_layoutData && window.innerWidth > 768) renderLayout(_layoutData);
    }, 300);
});

// 자동 새로고침 (10~300초 조절)
let _refreshInterval = 60;
let _refreshSec = _refreshInterval;

function changeInterval(delta){
    _refreshInterval = Math.max(10, Math.min(300, _refreshInterval + delta));
    _refreshSec = Math.min(_refreshSec, _refreshInterval);
    const rt=document.getElementById('refresh-timer');
    if(rt) rt.textContent=_refreshInterval+'초';
}

setInterval(()=>{
    _refreshSec--;
    if(_refreshSec <= 0){
        _refreshSec = _refreshInterval;
        if(_layoutData) renderLayout(_layoutData);
    }
    const rt=document.getElementById('refresh-timer');
    if(rt) rt.textContent=_refreshSec+'초';
}, 1000);

// 테마 (로컬스토리지에서 복원)
if(localStorage.getItem('theme')==='light') document.body.classList.add('light');
</script>
<script>function tick(){const d=new Date();const el=document.getElementById('clk');if(el)el.textContent=d.getFullYear()+'.'+String(d.getMonth()+1).padStart(2,'0')+'.'+String(d.getDate()).padStart(2,'0')+' '+d.toLocaleTimeString('ko-KR');}setInterval(tick,1000);tick();</script>
</body>
</html>